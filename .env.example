# Copy to .env and fill in. Only SECRET_KEY is required.
# `make dev` sources .env; production: export these before `open-refinery serve`.

# REQUIRED — signs session tokens and encrypts all stored secrets (service
# credentials, OAuth client secrets, settings). Generate:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me

# Optional server config (sensible defaults shown).
# PORT=8000
# DATABASE_URL=sqlite:///open-refinery.db
# LOG_LEVEL=INFO

# Optional — public base URL, used to build OAuth callbacks behind a proxy.
# APP_BASE_URL=https://open-refinery.example.com

# NOTE: OAuth provider client id/secret (GitHub, GitLab) and other connection
# credentials are now configured IN THE APP by admin/platform (encrypted in the
# database) — not here. The GITHUB_CLIENT_ID/SECRET, GITLAB_CLIENT_ID/SECRET env
# vars still work as a fallback if you prefer, but the UI is the intended path.
