# Copy to .env and fill in. Only SECRET_KEY is required to run.
# `make dev` sources .env; production: export these before `open-refinery serve`.

# REQUIRED — signs session tokens and encrypts stored service credentials.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me

# Optional server config (sensible defaults shown).
# PORT=8000
# DATABASE_URL=sqlite:///open-refinery.db
# LOG_LEVEL=INFO

# Optional — enable "Sign in with GitHub" and GitHub OAuth service connections.
# Register an OAuth App; callbacks: <base>/auth/github/callback and
# <base>/integrations/github/oauth/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Optional — enable GitLab OAuth service connections.
# GITLAB_CLIENT_ID=
# GITLAB_CLIENT_SECRET=

# Optional — public base URL, used to build OAuth callbacks behind a proxy.
# APP_BASE_URL=https://open-refinery.example.com
